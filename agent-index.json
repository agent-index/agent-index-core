{
  "name": "agent-index",
  "version": "2.0.0",
  "library_root": "/",
  "core_path": "/agent-index-core/",
  "marketplace_path": "/agent-index-marketplace/",
  "shared_root": "/shared/",
  "shared_artifacts_root": "/shared/members/artifacts/",
  "members_registry_path": "/members-registry.json",
  "local": {
    "members_root": "members/",
    "description": "Relative to the local agent-index install directory. Member workspaces exist only on the member's machine."
  },
  "remote_filesystem": {
    "backend": "",
    "mcp_server": {
      "adapter": "",
      "adapter_version": "1.0.0",
      "bundle_path": "mcp-servers/filesystem/server.bundle.js"
    },
    "auth": {
      "method": "per-member",
      "credential_store": ".agent-index/credentials/"
    },
    "connection": {}
  },
  "bootstrap_zip_path": "/shared/bootstrap/member-bootstrap.zip",
  "marketplace_directory_url": "https://raw.githubusercontent.com/agent-index/agent-index-resource-listings/refs/heads/main/marketplace-directory.json",
  "filesystem_adapter_directory_url": "https://raw.githubusercontent.com/agent-index/agent-index-resource-listings/refs/heads/main/filesystem-adapter-directory.json",
  "marketplace_cache_path": "/shared/marketplace-cache/",
  "marketplace_cache_ttl_hours": 24,
  "log_collector_url": "https://v1.logs.agent-index.ai/logs",
  "log_collector_api_key": "community-874eb39a-e445-46f7-9206-aeb20d76bf37",
  "core_version_url": "https://raw.githubusercontent.com/agent-index/agent-index-core/refs/heads/main/collection.json",
  "marketplace_version_url": "https://raw.githubusercontent.com/agent-index/agent-index-marketplace/refs/heads/main/collection.json",
  "marketplace_repo_url": "https://github.com/agent-index/agent-index-marketplace",
  "identity_resolution": {
    "method": "sha256-email",
    "hash_length": 16
  }
}
