{
  "name": "agent-index-core",
  "display_name": "Agent-Index Core",
  "version": "3.1.1",
  "description": "Core infrastructure for the agent-index system. Provides session management, member bootstrap, org setup, preferences management, and the system tutorial. v3.0.5: natural language triggers as first-class collection contract \u2014 triggers in collection.json, routing.json per member, session-start loads dynamic routing, org-setup writes defaults, preferences-management edits routing, author-collection and validate-collection updated. v3.0.4: CLAUDE.md natural-language-first routing. v3.0.3: deterministic API path patterns. v3.0.2: canonical CLAUDE.md template. v3.0.1: paste-URL-back OAuth flow. v3.0.0: on-demand executor.",
  "author": "agent-index",
  "license": "proprietary",
  "category": "infrastructure",
  "agent_index_min_version": "3.0.0",
  "api": [
    "session-start",
    "member-bootstrap",
    {
      "name": "org-setup",
      "triggers": [
        {
          "phrase": "set up my workspace",
          "capability": "org-setup",
          "description": "Run first-time member onboarding and capability installation"
        },
        {
          "phrase": "install my collections",
          "capability": "org-setup",
          "description": "Install or reinstall available collections"
        },
        {
          "phrase": "set up agent-index",
          "capability": "org-setup",
          "description": "Initialize agent-index member workspace"
        }
      ]
    },
    {
      "name": "preferences-management",
      "triggers": [
        {
          "phrase": "change my preferences",
          "capability": "preferences-management",
          "description": "View or modify session preferences and settings"
        },
        {
          "phrase": "edit my settings",
          "capability": "preferences-management",
          "description": "Adjust member configuration options"
        },
        {
          "phrase": "update my preferences",
          "capability": "preferences-management",
          "description": "Change session behavior settings"
        },
        {
          "phrase": "edit my routing",
          "capability": "preferences-management",
          "description": "Customize natural language trigger mappings"
        }
      ]
    },
    {
      "name": "system-tutorial",
      "triggers": [
        {
          "phrase": "how does this work",
          "capability": "system-tutorial",
          "description": "Get a guided tour of the agent-index system"
        },
        {
          "phrase": "show me around",
          "capability": "system-tutorial",
          "description": "Walk through agent-index features and concepts"
        },
        {
          "phrase": "what can you do",
          "capability": "system-tutorial",
          "description": "Learn about available agent-index capabilities"
        }
      ]
    },
    "create-org",
    "edit-org",
    {
      "name": "invite-member",
      "triggers": [
        {
          "phrase": "invite a member",
          "capability": "invite-member",
          "description": "Onboard a new agent-index member to this org"
        },
        {
          "phrase": "add a member",
          "capability": "invite-member",
          "description": "Add a new member to the org"
        },
        {
          "phrase": "invite someone",
          "capability": "invite-member",
          "description": "Invite a new member by email"
        },
        {
          "phrase": "onboard a new member",
          "capability": "invite-member",
          "description": "Run the new-member onboarding flow"
        }
      ]
    },
    {
      "name": "remove-member",
      "triggers": [
        {
          "phrase": "remove a member",
          "capability": "remove-member",
          "description": "Remove a member from the agent-index roster"
        },
        {
          "phrase": "offboard a member",
          "capability": "remove-member",
          "description": "Take a departing member out of the registry"
        },
        {
          "phrase": "delete a member",
          "capability": "remove-member",
          "description": "Remove a member entry from the registry"
        },
        {
          "phrase": "take someone off",
          "capability": "remove-member",
          "description": "Remove a member when they leave"
        }
      ]
    },
    {
      "name": "view-permissions",
      "triggers": [
        {
          "phrase": "who can see this",
          "capability": "view-permissions",
          "description": "Show who has access to a resource"
        },
        {
          "phrase": "show permissions",
          "capability": "view-permissions",
          "description": "Display the permission list for a resource"
        },
        {
          "phrase": "who has access",
          "capability": "view-permissions",
          "description": "List members and groups with access to a resource"
        },
        {
          "phrase": "view permissions",
          "capability": "view-permissions",
          "description": "Inspect ACLs on a resource"
        }
      ]
    },
    {
      "name": "view-audit",
      "triggers": [
        {
          "phrase": "show audit trail",
          "capability": "view-audit",
          "description": "Open the audit trail for a resource"
        },
        {
          "phrase": "who changed this",
          "capability": "view-audit",
          "description": "Show recent changes and who made them"
        },
        {
          "phrase": "audit log for",
          "capability": "view-audit",
          "description": "Surface activity history for a resource"
        },
        {
          "phrase": "view activity",
          "capability": "view-audit",
          "description": "See the activity stream on a resource"
        }
      ]
    },
    {
      "name": "verify-workspace-policy",
      "triggers": [
        {
          "phrase": "verify workspace policy",
          "capability": "verify-workspace-policy",
          "description": "Run the workspace policy diagnostic"
        },
        {
          "phrase": "check workspace setup",
          "capability": "verify-workspace-policy",
          "description": "Confirm Workspace settings support the access-control model"
        },
        {
          "phrase": "diagnose permissions setup",
          "capability": "verify-workspace-policy",
          "description": "Verify the org's permission configuration"
        }
      ]
    },
    "publish-updates",
    {
      "name": "apply-updates",
      "triggers": [
        {
          "phrase": "check for updates",
          "capability": "apply-updates",
          "description": "Check and apply pending org updates"
        },
        {
          "phrase": "update my workspace",
          "capability": "apply-updates",
          "description": "Apply the latest org changes to local install"
        },
        {
          "phrase": "am I up to date",
          "capability": "apply-updates",
          "description": "Check if there are pending updates to apply"
        }
      ]
    },
    {
      "name": "author-collection",
      "triggers": [
        {
          "phrase": "create a collection",
          "capability": "author-collection",
          "description": "Build a new agent-index collection from scratch"
        },
        {
          "phrase": "build a collection",
          "capability": "author-collection",
          "description": "Author a new collection with guided workflow"
        },
        {
          "phrase": "start a new collection",
          "capability": "author-collection",
          "description": "Scaffold a new collection project"
        }
      ]
    },
    {
      "name": "validate-collection",
      "triggers": [
        {
          "phrase": "validate my collection",
          "capability": "validate-collection",
          "description": "Check a collection for standards compliance"
        },
        {
          "phrase": "check my collection",
          "capability": "validate-collection",
          "description": "Run validation checks on a collection"
        }
      ]
    },
    "upload-install-log"
  ],
  "dependencies": [],
  "external_dependencies": [],
  "eol_date": null,
  "marketplace_url": "https://github.com/agent-index/agent-index-core",
  "support_url": "https://agent-index.ai/support"
}